{
  "name": "sanft-desktop",
  "version": "0.0.2",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "description": "Sanft - AI Chat Desktop App powered by Electron.",
  "main": "electron/main.js",
  "scripts": {
    "prepare": "husky",
    "dev": "./dev.sh",
    "install:all": "pnpm --dir apps/main install && pnpm --dir apps/window install && pnpm --dir apps/backend install",
    "build:web": "pnpm --dir apps/main build && pnpm --dir apps/window build",
    "build:backend": "pnpm --dir apps/backend build",
    "build:electron": "esbuild electron-src/main.ts electron-src/launcher_preload.ts electron-src/deepseek_login_preload.ts --bundle --platform=node --format=cjs --external:electron --external:@ziuchen/deepseek-api/package.json --external:sql.js --external:sql.js/* --outdir=electron",
    "build:fast-window": "esbuild apps/fast-window/src/fast_input.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=apps/fast-window/fast_input.js",
    "sync:assets": "node scripts/sync-assets.cjs",
    "build": "pnpm build:electron && pnpm build:fast-window && pnpm build:web && pnpm build:backend && pnpm sync:assets",
    "dev:main": "pnpm --dir apps/main dev",
    "dev:window": "pnpm --dir apps/window dev",
    "dev:backend": "pnpm --dir apps/backend watch",
    "start": "pnpm build:electron && pnpm build:fast-window && node scripts/run-electron.cjs",
    "start:built": "pnpm build && node scripts/run-electron.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm --dir apps/main typecheck && pnpm --dir apps/window typecheck && pnpm --dir apps/backend typecheck && pnpm typecheck:electron",
    "typecheck:electron": "tsc -p electron-src/tsconfig.json --noEmit",
    "test": "vitest run",
    "check:no-js-source": "node scripts/check-no-js-source.cjs",
    "check:no-inline-js": "node scripts/check-no-inline-js.cjs",
    "check": "pnpm check:no-js-source && pnpm check:no-inline-js",
    "ci:quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm check",
    "ci": "pnpm ci:quality && pnpm build",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg --publish never",
    "dist:linux": "pnpm build && electron-builder --linux AppImage --publish never",
    "dist:all:ci": "pnpm build && electron-builder --publish never"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "electron": "42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.sanft.desktop",
    "productName": "Sanft",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "runtime/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build",
      "maintainer": "Sanft Team <y-shi23tsinghua@outlook.com>"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,cjs,mjs,json,css,md,html}": [
      "prettier --write"
    ],
    "*.{ts,tsx,vue,js,cjs,mjs}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@ziuchen/deepseek-api": "^2.0.0",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1"
  }
}
